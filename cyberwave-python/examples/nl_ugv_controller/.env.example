# Cyberwave platform
CYBERWAVE_API_KEY=
# UUIDs of the UGV Beast twin and its environment, from the Cyberwave dashboard.
CYBERWAVE_TWIN_ID=
CYBERWAVE_ENVIRONMENT_ID=
# Camera settings (used in --vision mode).
CW_CAMERA_INDEX=0
CW_CAMERA_WIDTH=1280
CW_CAMERA_HEIGHT=720
CW_CAMERA_JPEG_QUALITY=80

# Gemini — LLM motion planner (free tier; see project notes on why Gemini
# instead of the paid Anthropic API)
GOOGLE_API_KEY=
GEMINI_MODEL=

# Mistral — Voxtral STT
MISTRAL_API_KEY=
MISTRAL_STT_MODEL=
# "simulation" (twin only — recommended for v1) | "live" (physical UGV Beast too)
CW_MODE=simulation

# Set to "true" to enable spacebar push-to-talk; otherwise typed input
VOICE_ENABLED=true
